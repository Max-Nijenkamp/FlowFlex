# Plain PHPStan, not Larastan — decision-2026-06-11-static-analysis-without-larastan.
# Model magic is covered by @property docblocks on every model.
parameters:
    level: 5
    paths:
        - app
        - database/factories
        - database/seeders
    ignoreErrors:
        # Structural, not a bug: BelongsToCompany's first production consumers
        # are the phase-1 core modules; until then only tests/Support/TestItem
        # (outside analysed paths) uses it. Remove when the first core model lands.
        -
            identifier: trait.unused
            path: app/Support/Traits/BelongsToCompany.php
    treatPhpDocTypesAsCertain: false
