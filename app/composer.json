{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "brick/money": "^0.11.2",
        "calebporzio/sushi": "^2.5",
        "codewithdennis/filament-select-tree": "^4.2",
        "dedoc/scramble": "^0.13.26",
        "ezyang/htmlpurifier": "^4.19",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-media-library-plugin": "^5.6",
        "inertiajs/inertia-laravel": "^3.1",
        "laravel/framework": "^13.8",
        "laravel/horizon": "^5.47",
        "laravel/pulse": "^1.7",
        "laravel/reverb": "^1.10",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^11.2",
        "laravel/tinker": "^3.0",
        "leandrocfe/filament-apex-charts": "^5.1",
        "lorisleiva/laravel-actions": "^2.10",
        "maatwebsite/excel": "^3.1",
        "meilisearch/meilisearch-php": "^1.16",
        "predis/predis": "^3.5",
        "propaganistas/laravel-phone": "^6.0",
        "pxlrbt/filament-excel": "^3.6",
        "sentry/sentry-laravel": "^4.25",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/icalendar-generator": "^3.3",
        "spatie/laravel-activitylog": "^5.0",
        "spatie/laravel-backup": "^10.3",
        "spatie/laravel-data": "^4.23",
        "spatie/laravel-health": "^1.40",
        "spatie/laravel-medialibrary": "^11.23",
        "spatie/laravel-model-states": "^2.14",
        "spatie/laravel-pdf": "^2.11",
        "spatie/laravel-permission": "^8.0",
        "spatie/laravel-schemaless-attributes": "^2.6",
        "spatie/laravel-settings": "^3.9",
        "spatie/laravel-sluggable": "^4.0",
        "spatie/laravel-tags": "^4.11",
        "spatie/laravel-typescript-transformer": "^3.2",
        "stripe/stripe-php": "^20.2",
        "tightenco/ziggy": "^2.6"
    },
    "require-dev": {
        "brianium/paratest": "^7.20",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.10",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.29",
        "laravel/telescope": "^5.20",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-livewire": "^4.1",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "pest"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "lint": [
            "pint"
        ],
        "analyse": [
            "phpstan analyse --memory-limit=1G"
        ],
        "ci": [
            "@lint",
            "@analyse",
            "@test"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
